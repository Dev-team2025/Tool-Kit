# Server configuration
PORT=5000

# Supabase (server-side)
# Your Supabase project URL (not secret)
SUPABASE_URL=https://zowsjpfqlwmwlaywlixt.supabase.co

# Service role key (SECRET) - keep this ONLY in server/.env, never in client
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# Optional fallback (NOT recommended unless you configure RLS policies)
# SUPABASE_ANON_KEY=your_supabase_anon_key

# Auth
JWT_SECRET=your_jwt_secret

# Email (Gmail)
EMAIL_USER=your_email@gmail.com
EMAIL_PASS=your_gmail_app_password
